<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Exercise 12: Basic Image Styling</title>
    <link rel="stylesheet" href="10.css">
</head>
<body>

<h1>Basic Image Styling Demo</h1>

<!-- 1️⃣ Image Dimensions -->
<img src="bacha.png" alt="Sample Image 1" class="img-dimensions">

<!-- 2️⃣ Borders and Border Radius -->
<img src="../images/gallery/sample2.jpg" alt="Sample Image 2" class="img-border">

<!-- 3️⃣ Object-fit and Object-position -->
<div class="object-fit-container">
    <img src="../images/gallery/sample3.jpg" alt="Sample Image 3" class="img-object-fit">
</div>

<!-- 4️⃣ Basic Image Filters -->
<img src="../images/gallery/sample4.jpg" alt="Sample Image 4" class="img-filters">

</body>
</html>